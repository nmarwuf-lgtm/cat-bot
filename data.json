,
  "terms": {
    "نايتنجيل": {
      "chapter": "1",
      "definition": "فلورنس نايتنجيل، مؤسسة التمريض الحديث، خفضت معدل الوفيات من 60% إلى 1% خلال حرب القرم، وغيرت الصورة السلبية للتمريض."
    },
    "الممارسة المبنية على الدليل": {
      "chapter": "1",
      "definition": "استخدام أحدث الأدلة العلمية للتنبؤ بالتدخلات التمريضية الأكثر فعالية لتحقيق النتائج المرجوة."
    },
    "نظرية البيئة": {
      "chapter": "1",
      "definition": "نظرية فلورنس نايتنجيل التي تؤكد أن الظروف الخارجية (التهوية، الضوء، النظافة) تؤثر على صحة المريض."
    },
    "ADLs": {
      "chapter": "1",
      "definition": "أنشطة الحياة اليومية (Activities of Daily Living) مثل الاستحمام، ارتداء الملابس، وتناول الطعام."
    },
    "Evidence-Based Practice": {
      "chapter": "1",
      "definition": "الممارسة المبنية على الدليل، وهي استخدام أفضل الأدلة العلمية المتاحة لاتخاذ القرارات السريرية."
    },
    "التعليم المستمر": {
      "chapter": "1",
      "definition": "أي تجربة تعلم مخططة تتجاوز برنامج التمريض الأساسي، لضمان الكفاءة المهنية مدى الحياة."
    },
    "مهارات التقييم": {
      "chapter": "1",
      "definition": "أفعال تتضمن جمع البيانات عن المريض من خلال المقابلات، الملاحظة، الفحص، ومراجعة السجلات الطبية."
    },
    "مهارات العناية": {
      "chapter": "1",
      "definition": "التدخلات التمريضية التي تستعيد صحة الفرد أو تحافظ عليها، مثل المساعدة في أنشطة الحياة اليومية."
    },
    "مهارات الإرشاد": {
      "chapter": "1",
      "definition": "تدخلات تشمل التواصل مع المرضى، الاستماع الفعال، وتقديم التثقيف الصحي المناسب."
    },
    "مهارات التهدئة": {
      "chapter": "1",
      "definition": "تدخلات توفر الاستقرار والأمان للمريض أثناء الأزمات الصحية."
    }
  }
}
